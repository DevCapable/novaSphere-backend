<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <style>
      body {
        font-family: Arial, sans-serif;
        font-size: 15px;
        margin: 0;
        padding: 0;
        -webkit-text-size-adjust: 100%;
        -ms-text-size-adjust: 100%;
      }

      p{
        padding: 0;
        margin: 0;
      }

      table {
        border-spacing: 0;
        width: 100%;
      }

      .container {
        width: 100%;
        max-width: 600px;
        margin: 0 auto;
        padding: 20px;
      }

      .header {
        text-align: center;
        padding: 1px 0;
      }
      .footer {
        text-align: center;
        padding: 10px 0;
      }

      .content {
        padding: 20px 0;
      }

      .footer {
        font-size: 12px;
        color: #777;
      }

      img {
        max-width: 100%;
        height: auto;
        border: 0;
        line-height: 100%;
        outline: none;
        text-decoration: none;
      }

      @media only screen and (max-width: 600px) {
        .container {
          padding: 10px;
        }

        .content {
          padding: 10px 0;
        }

        .header,
        .footer {
          padding: 5px 0;
        }
      }
    </style>
  </head>

  <body>
    <table role="presentation" class="container">
      <tr>
        <td class="header"><%- include('header', { logo: logo }) %></td>
      </tr>
      <tr>
        <td class="content"><%- include(partialTemplate, data) %></td>
      </tr>
      <tr>
        <td class="header"><%- include('footer') %></td>
      </tr>
    </table>
  </body>
</html>
