<tr>
    <td style="padding-bottom: 10px">
      Dear User,
    </td>
  </tr>
  
  <tr>
    <td style="padding-bottom: 10px">
      We received a request to log in to your NOVASPHERE account. To complete your
      login, please use the One-Time Password (OTP) below.
    </td>
  </tr>
  
  <tr>
    <td style="padding-bottom: 15px; text-align: center;">
      <div
        style="
          display: inline-block;
          padding: 12px 24px;
          font-size: 22px;
          font-weight: bold;
          letter-spacing: 4px;
          background-color: #f4f6f8;
          border-radius: 6px;
          color: #000;
        "
      >
        <%= otp %>
      </div>
    </td>
  </tr>
  
  <tr>
    <td style="padding-bottom: 10px">
      This OTP is valid for <strong>5 minutes</strong>. Please do not share this
      code with anyone.
    </td>
  </tr>
  
  <tr>
    <td style="padding-bottom: 10px">
      <strong>Didn’t request this login?</strong>
    </td>
  </tr>
  
  <tr>
    <td style="padding-bottom: 10px">
      If you did not initiate this login attempt, please ignore this email or
      contact our support team immediately at
      <a href="mailto:support@novasphere.com">support@novasphere.com</a> or call
      01-6310962.
    </td>
  </tr>
  
  <tr>
    <td style="padding-bottom: 10px">
      <strong>Need Help?</strong>
    </td>
  </tr>
  
  <tr>
    <td style="padding-bottom: 10px">
      For any questions or assistance, please reach out to our support team at
      <a href="mailto:support@novasphere.com">support@novasphere.com</a>.
    </td>
  </tr>
  
  <tr>
    <td style="padding-bottom: 10px">
      Thank you for choosing NOVASPHERE.
    </td>
  </tr>
  
  <tr>
    <td style="padding-bottom: 10px">
      Sincerely,
    </td>
  </tr>
  
  <tr>
    <td style="padding-bottom: 10px">
      The NOVASHERE Team
    </td>
  </tr>
  