<tr>
  <td style="padding-bottom:16px;font-family:Arial;font-size:14px;color:#333;">
    Hello <strong><%= companyName %></strong>, 
    The status of your NCTRC Training Course request has been updated.
  </td>
</tr>
<tr>
  <td style="padding-bottom:20px;">
    <table width="100%" style="border:1px solid #e5e7eb;border-radius:6px;font-family:Arial;font-size:14px;color:#333;border-collapse:collapse;">
      <tr>
        <td style="padding:10px 14px;background:#f9fafb;font-weight:600;width:200px;border-bottom:1px solid #e5e7eb;">Specialization</td>
        <td style="padding:10px 14px;border-bottom:1px solid #e5e7eb;"><%= type.name %> (<%= type.code %>)</td>
      </tr>
      <tr>
        <td style="padding:10px 14px;background:#f9fafb;font-weight:600;border-bottom:1px solid #e5e7eb;">Course</td>
        <td style="padding:10px 14px;border-bottom:1px solid #e5e7eb;"><%= courseName %> (<%= courseCode %>)</td>
      </tr>
      <tr>
        <td style="padding:10px 14px;background:#f9fafb;font-weight:600;">Status</td>
        <td style="padding:10px 14px;">
          <% if (status == 1) { %>
            <span style="color:#16a34a;font-weight:bold;">APPROVED</span>
          <% } else { %>
            <span style="color:#dc2626;font-weight:bold;">NOT ACTIVE</span>
          <% } %>
        </td>
      </tr>
    </table>
  </td>
</tr>
<tr>
  <td style="padding:16px 0;font-family:Arial;font-size:14px;color:#333;">
    <% if (status == 1) { %>
      Good news! This course is now <strong>Active</strong>. You can now use it for your applications in the portal.
    <% } else { %>
      Your course is currently <strong>Not Active</strong>. It may be under review or has been deactivated by the administrator.
    <% } %>
  </td>
</tr>