<tr>
  <td style="padding-bottom:16px; font-family: Arial, sans-serif; font-size:14px; color:#333333;">
    Dear <strong><%= companyName %></strong>,
    <br /><br />
    Your request to add new <strong>NCTRC Training Courses</strong> has been successfully submitted.
    The requested courses will go through an approval process by the NCTRC agency team.
  </td>
</tr>

<tr>
  <td style="padding-bottom:20px;">
    <table
      cellpadding="0"
      cellspacing="0"
      width="100%"
      style="
        max-width:520px;
        border:1px solid #e5e7eb;
        border-radius:6px;
        font-family: Arial, sans-serif;
        font-size:14px;
        color:#333333;
        border-collapse: collapse;
      "
    >
      <tr>
        <td style="padding:10px 14px; background:#f9fafb; font-weight:600; width:45%; border-bottom:1px solid #e5e7eb;">
          Area of Specialization
        </td>
        <td style="padding:10px 14px; border-bottom:1px solid #e5e7eb;">
          <%= type.name %>
        </td>
      </tr>

      <% if (createdCourses && createdCourses.length > 0) { %>
      <tr>
        <td style="padding:10px 14px; background:#f9fafb; font-weight:600; border-bottom:1px solid #e5e7eb;">
          Requested Courses
        </td>
        <td style="padding:10px 14px; border-bottom:1px solid #e5e7eb;">
          <% createdCourses.forEach(function(course){ %>
            <div style="margin-bottom:2px;">• <%= course %></div>
          <% }) %>
        </td>
      </tr>
      <% } %>

      <% if (skippedCourses && skippedCourses.length > 0) { %>
      <tr>
        <td style="padding:10px 14px; background:#f9fafb; font-weight:600;">
          Existing / Pending Approval
        </td>
        <td style="padding:10px 14px;">
          <% skippedCourses.forEach(function(course){ %>
            <div style="color:#666; margin-bottom:2px;">• <%= course %></div>
          <% }) %>
        </td>
      </tr>
      <% } %>

    </table>
  </td>
</tr>

<tr>
  <td style="padding-top:10px; font-family: Arial, sans-serif; font-size:14px; color:#333333;">
    Kindly allow some time for the approval process. Once approved, the courses will become available for selection in the system.
    <br /><br />
    Thank you.
  </td>
</tr>