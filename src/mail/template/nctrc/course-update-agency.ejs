<tr>
  <td style="padding-bottom:16px;font-family:Arial;font-size:14px;color:#333;">
    An update has been made to an <strong>NCTRC Training Course</strong> record.
  </td>
</tr>
<tr>
  <td style="padding-bottom:20px;">
    <table width="100%" style="border:1px solid #e5e7eb;border-radius:6px;font-family:Arial;font-size:14px;color:#333;border-collapse:collapse;">
      <tr>
        <td style="padding:10px 14px;background:#f9fafb;font-weight:600;width:200px;border-bottom:1px solid #e5e7eb;">Company</td>
        <td style="padding:10px 14px;border-bottom:1px solid #e5e7eb;"><%= company %></td>
      </tr>
      <tr>
        <td style="padding:10px 14px;background:#f9fafb;font-weight:600;border-bottom:1px solid #e5e7eb;">Specialization</td>
        <td style="padding:10px 14px;border-bottom:1px solid #e5e7eb;"><%= type.name %> (<%= type.code %>)</td>
      </tr>
      <tr>
        <td style="padding:10px 14px;background:#f9fafb;font-weight:600;border-bottom:1px solid #e5e7eb;">Course</td>
        <td style="padding:10px 14px;border-bottom:1px solid #e5e7eb;"><%= courseName %></td>
      </tr>
      <tr>
        <td style="padding:10px 14px;background:#f9fafb;font-weight:600;">Status Change</td>
        <td style="padding:10px 14px;">
          <%= previousStatus == 1 ? 'Active' : 'Pending' %> ➔ 
          <strong style="color:#2563eb;"><%= newStatus == 1 ? 'Active' : 'Pending' %></strong>
        </td>
      </tr>
    </table>
  </td>
</tr>
