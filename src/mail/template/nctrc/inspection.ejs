<tr>
  <td style="padding-bottom:16px; font-family: Arial, sans-serif; font-size:14px; color:#333333;">
    An <strong>NCTRC Application</strong> has been scheduled for inspection.
    Please find the details below:
  </td>
</tr>

<tr>
  <td style="padding-bottom:20px;">
    <table
      cellpadding="0"
      cellspacing="0"
      width="100%"
      style="
        max-width:520px;
        border:1px solid #e5e7eb;
        border-radius:6px;
        font-family: Arial, sans-serif;
        font-size:14px;
        color:#333333;
      "
    >
      <!-- Company -->
      <tr>
        <td
          style="
            padding:10px 14px;
            background:#f9fafb;
            font-weight:600;
            width:45%;
            border-bottom:1px solid #e5e7eb;
          "
        >
          Company
        </td>
        <td style="padding:10px 14px; border-bottom:1px solid #e5e7eb;">
          <%= company %>
        </td>
      </tr>

      <!-- Application Number -->
      <tr>
        <td
          style="
            padding:10px 14px;
            background:#f9fafb;
            font-weight:600;
            border-bottom:1px solid #e5e7eb;
          "
        >
          Application Number
        </td>
        <td style="padding:10px 14px; border-bottom:1px solid #e5e7eb;">
          <%= applicationCode %>
        </td>
      </tr>

      <!-- Inspection Date -->
      <tr>
        <td
          style="
            padding:10px 14px;
            background:#f9fafb;
            font-weight:600;
            border-bottom:1px solid #e5e7eb;
          "
        >
          Inspection Date
        </td>
        <td style="padding:10px 14px; border-bottom:1px solid #e5e7eb;">
          <%= inspectionDate %>
        </td>
      </tr>

      <!-- Comment -->
      <tr>
        <td
          style="
            padding:10px 14px;
            background:#f9fafb;
            font-weight:600;
            vertical-align:top;
          "
        >
          Comment to Company
        </td>
        <td style="padding:10px 14px;">
          <%= inspectionComment %>
        </td>
      </tr>
    </table>
  </td>
</tr>

<tr>
  <td
    style="
      padding-top:10px;
      font-family: Arial, sans-serif;
      font-size:14px;
      color:#333333;
    "
  >
    Thank you.
  </td>
</tr>