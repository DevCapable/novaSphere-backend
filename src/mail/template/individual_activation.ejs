<tr>
  <td style="padding-bottom: 10px">
    Welcome to the NOGIC JQS (Nigerian Oil and Gas Industry Content Joint
    Qualification System) Portal, <%= firstName %> <%= lastName %>.
  </td>
</tr>

<tr>
  <td style="padding-bottom: 10px">
    You have been successfully signed up on the NOGIC JQS Portal. You need to
    activate your account before logging into the portal to complete your
    details.
  </td>
</tr>

<tr>
  <td style="padding-bottom: 10px">
    To activate your account, <a href="<%= url %>">click here</a>.
  </td>
</tr>

<tr>
  <td style="padding-bottom: 10px">
    Or point your browser to this address: <%= url %>
  </td>
</tr>

<tr>
  <td style="padding-bottom: 10px">
    <strong>Your Portal Account Details:</strong>
  </td>
</tr>

<tr>
  <td style="padding-bottom: 10px">
    <table cellpadding="0" cellspacing="0" width="50%">
      <tr>
        <td>Email Address:</td>
        <td><%= email %></td>
      </tr>
      <tr>
        <td>Password:</td>
        <td><%= password %></td>
      </tr>
    </table>
  </td>
</tr>

<tr>
  <td style="padding-bottom: 10px">Thank You.</td>
</tr>
